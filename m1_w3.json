      "id": "grammar_possessives",
      "type": "grammar_table",
      "title": "Grammatik: Ejeformer — Possessives",
      "explanation": "Danish possessives change depending on the gender of the noun they describe — not the owner. Use 'min' with en-words (common gender), 'mit' with et-words (neuter), and 'mine' with plurals. The same pattern applies to din/dit/dine (your), hans (his), hendes (her), and vores (our).",
      "headers": ["", "en-ord (en far)", "et-ord (et barn)", "flertal (børn)"],
      "rows": [
        { "label": "jeg → my", "answers": ["min", "mit", "mine"] },
        { "label": "du → your", "answers": ["din", "dit", "dine"] },
        { "label": "han → his", "answers": ["hans", "hans", "hans"] },
        { "label": "hun → her", "answers": ["hendes", "hendes", "hendes"] },
        { "label": "vi → our", "answers": ["vores", "vores", "vores"] },
        { "label": "de → their", "answers": ["deres", "deres", "deres"] }
      ]
    },

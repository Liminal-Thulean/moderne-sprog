        {
          "question": "Hvor bor Yasmins bedsteforældre?",
          "answer": "De bor i Marokko."
        },
        {
          "question": "Hvor mange kusiner har Yasmin?",
          "answer": "Hun har to kusiner: Nadia og Lina."
        }

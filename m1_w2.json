      "type": "grammar_table",
      "title": "Grammatik: Være, hedde, have",
      "explanation": "These three verbs are the most important in Danish. Unlike English, Danish verbs do not change form based on the person — 'jeg er', 'du er', 'han er' all use the same form 'er'. This makes Danish verb conjugation much simpler than German or French.",
      "headers": ["", "være (to be)", "hedde (to be called)", "have (to have)"],
      "rows": [
        { "label": "jeg (I)",         "answers": ["er", "hedder", "har"] },
        { "label": "du (you)",         "answers": ["er", "hedder", "har"] },
        { "label": "han/hun (he/she)", "answers": ["er", "hedder", "har"] },
        { "label": "vi (we)",          "answers": ["er", "hedder", "har"] },
        { "label": "I (you pl.)",      "answers": ["er", "hedder", "har"] },
        { "label": "de (they)",        "answers": ["er", "hedder", "har"] }
      ]
